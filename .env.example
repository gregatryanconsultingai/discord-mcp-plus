# Required
DISCORD_TOKEN=your_bot_token_here

# Optional — default server ID (makes guildId optional in all tools)
# DISCORD_GUILD_ID=your_server_id

# Safety controls
# DISCORD_MCP_READONLY=false
# DISCORD_MCP_TOOLS=tool1,tool2
# DISCORD_MCP_TOOLS_DENY=delete_channel,ban_member
# DISCORD_MCP_CHANNELS=channel_id_1,channel_id_2
# DISCORD_MCP_DRY_RUN=false
# DISCORD_MCP_AUDIT_LOG=off

# Transport (only stdio supported in v0.1)
# TRANSPORT=stdio
