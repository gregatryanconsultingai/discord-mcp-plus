# Required
DISCORD_TOKEN=your_bot_token_here

# Optional — default server ID (makes guildId optional in all tools)
# DISCORD_GUILD_ID=your_server_id

# Safety controls
# DISCORD_MCP_READONLY=false
# DISCORD_MCP_TOOLS=tool1,tool2
# DISCORD_MCP_TOOLS_DENY=delete_channel,ban_member
# DISCORD_MCP_CHANNELS=channel_id_1,channel_id_2
# DISCORD_MCP_DRY_RUN=false
# DISCORD_MCP_AUDIT_LOG=off

# Transport — 'stdio' (default, for npx/local use) or 'http' (for Docker/remote)
# DISCORD_MCP_TRANSPORT=stdio

# HTTP transport — port to listen on (default 3000)
# DISCORD_MCP_HTTP_PORT=3000

# HTTP transport — bearer token for auth (REQUIRED when transport=http)
# DISCORD_MCP_HTTP_TOKEN=your-secret-token-here
