# ── Required ──────────────────────────────────────────────────────────────────

# The Discord channel ID to watch for @mentions
DISCORD_CHANNEL_ID=your_channel_id

# The bot's Discord user ID (found in Developer Portal or by right-clicking the bot)
DISCORD_BOT_ID=your_bot_user_id

# The bot's username (used to filter out the bot's own messages)
DISCORD_BOT_USERNAME=your_bot_username

# ── MCP server connection ──────────────────────────────────────────────────────

# URL of your discord-mcp-plus HTTP server
MCP_URL=http://localhost:3000/mcp

# Bearer token — must match DISCORD_MCP_HTTP_TOKEN in your MCP server config
MCP_TOKEN=your_mcp_http_token

# ── Optional ───────────────────────────────────────────────────────────────────

# How often to poll for new messages (seconds)
POLL_SECS=10

# System prompt injected before every claude -p call.
# Customize this to give your bot its personality.
# BOT_PROMPT=You are a witty and self-aware Discord bot connected to Discord via MCP. Keep replies conversational, clever, and punchy — 1-2 sentences max. No hashtags, no emoji overload.
